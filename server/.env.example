# ═══════════════════════════════════════════
# LixiOps Server — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to version control
# ═══════════════════════════════════════════

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/lixiops?schema=public"

# JWT
JWT_SECRET="generate-a-64-char-random-string-here"
JWT_REFRESH_SECRET="generate-another-64-char-random-string-here"

# Session
SESSION_TIMEOUT_HOURS=8

# Encryption
ENCRYPTION_KEY="generate-a-32-byte-hex-key-here"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"

# Resend (Email)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@codelixi.com"

# Twilio / WATI (SMS/WhatsApp)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Google Calendar
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""

# AWS Rekognition (face recognition fallback)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

# Redis (rate limiting, BullMQ)
REDIS_URL="redis://localhost:6379"

# Server
PORT=4000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"

# Biometric
BIOMETRIC_ENCRYPTION_KEY="generate-separate-32-byte-hex-key"

# File Upload
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES="image/png,image/jpeg,image/gif,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document"

# Seed bootstrap CEO (used by `npm run db:seed` on first boot)
# Override these in production so the default isn't used.
# SEED_CEO_EMAIL="you@codelixi.com"
# SEED_CEO_PASSWORD="ChangeThisImmediately!"
# SEED_CEO_NAME="Your Name"
